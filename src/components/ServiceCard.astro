---
const {
  title,
  description,
  tag,
  accent = "green",
  class: className = ""
} = Astro.props;

const accentClass = accent === "purple" ? "text-brand-purple" : "text-brand-green";
const borderClass = accent === "purple" ? "border-brand-purple/40" : "border-brand-green/40";
---

<div class={`bento-card ${borderClass} ${className}`} data-accent={accent}>
  <div class="flex items-center gap-3">
    <div class={`icon-chip ${accentClass}`} aria-hidden="true">
      <slot name="icon" />
    </div>
    <span class="text-xs font-mono uppercase tracking-[0.3em] text-white/50">{tag}</span>
  </div>
  <h3 class="mt-4 text-xl font-mono">{title}</h3>
  <p class="mt-3 text-sm leading-relaxed text-white/70">{description}</p>
</div>
