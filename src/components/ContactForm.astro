<form class="bento-card space-y-4 border-brand-purple/30" data-accent="purple">
  <div>
    <label class="text-xs font-mono uppercase tracking-[0.3em] text-white/50" for="nombre">
      Nombre
    </label>
    <input
      class="field-input mt-2"
      id="nombre"
      name="nombre"
      type="text"
      placeholder="Tu nombre"
      required
    />
  </div>
  <div>
    <label class="text-xs font-mono uppercase tracking-[0.3em] text-white/50" for="email">
      Email
    </label>
    <input
      class="field-input mt-2"
      id="email"
      name="email"
      type="email"
      placeholder="tu@empresa.com"
      required
    />
  </div>
  <div>
    <label class="text-xs font-mono uppercase tracking-[0.3em] text-white/50" for="servicio">
      Servicio principal
    </label>
    <input
      class="field-input mt-2"
      id="servicio"
      name="servicio"
      type="text"
      placeholder="Desarrollo Web, Electronica, IA..."
    />
  </div>
  <div>
    <label class="text-xs font-mono uppercase tracking-[0.3em] text-white/50" for="mensaje">
      Briefing
    </label>
    <textarea
      class="field-textarea mt-2"
      id="mensaje"
      name="mensaje"
      placeholder="Describe el desafio, contexto y objetivos."
      required
    ></textarea>
  </div>
  <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
    <button class="btn-primary w-full sm:w-auto" type="submit">Enviar briefing</button>
    <span class="text-xs text-white/50">Respuesta en menos de 24 horas habiles.</span>
  </div>
</form>
