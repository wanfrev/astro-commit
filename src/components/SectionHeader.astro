---
const { eyebrow, title, subtitle, accent = "green" } = Astro.props;
const accentClass = accent === "purple" ? "text-brand-purple" : "text-brand-green";
---

<div class="max-w-2xl">
  <p class={`section-label ${accentClass}`}>{eyebrow}</p>
  <h2 class="section-title">{title}</h2>
  <p class="section-text">{subtitle}</p>
</div>
