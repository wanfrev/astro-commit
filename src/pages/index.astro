---
import BaseLayout from "../layouts/BaseLayout.astro";
import NavBar from "../components/NavBar.astro";
import SectionHeader from "../components/SectionHeader.astro";
import ServiceCard from "../components/ServiceCard.astro";
import StatCard from "../components/StatCard.astro";
import ContactForm from "../components/ContactForm.astro";
import Footer from "../components/Footer.astro";
---

<BaseLayout
	title="Commit | Ingenieria de confianza"
	description="Auditoria, IA e IoT con precision, seguridad y trazabilidad de extremo a extremo."
>
	<NavBar />
	<main>
		<section class="relative overflow-hidden pt-32 pb-20">
			<div class="hero-aurora absolute inset-0 opacity-90"></div>
			<div class="hero-grid absolute inset-0 opacity-30"></div>
			<div class="glow-orb -top-24 right-0 h-72 w-72 bg-brand-purple/30 animate-float-slow"></div>
			<div class="glow-orb -bottom-24 left-0 h-72 w-72 bg-brand-green/25 animate-float"></div>
			<div class="page-container relative z-10">
				<div class="grid gap-12 lg:grid-cols-[1.1fr_0.9fr] lg:items-center">
					<div>
						<p class="section-label text-brand-green">Ingenieria que escala tus ideas</p>
						<h1 class="mt-6 text-4xl font-mono leading-tight md:text-5xl lg:text-6xl">
							Commit: <span class="gradient-text">Desarrollo</span> de software y
							<span class="text-brand-purple">Sistemas</span> electronicos
						</h1>
						<p class="mt-6 text-lg text-white/70">
							Construimos aplicaciones de alto rendimiento y hardware a medida.
							Potenciamos tu infraestructura con IA y aseguramos la integridad mediante
							auditoria tecnica.
						</p>
						<div class="mt-8 flex flex-wrap gap-4">
							<a class="btn-primary" href="#contacto">Agenda diagnostico</a>
							<a class="btn-secondary" href="#servicios">Explorar servicios</a>
						</div>
						<div class="mt-10 grid gap-4 text-xs font-mono uppercase tracking-[0.25em] text-white/50 sm:grid-cols-3">
							<div class="flex items-center gap-2">
								<span class="h-1.5 w-1.5 rounded-full bg-brand-green"></span>
								Auditoria continua
							</div>
							<div class="flex items-center gap-2">
								<span class="h-1.5 w-1.5 rounded-full bg-brand-purple"></span>
								IA explicable
							</div>
							<div class="flex items-center gap-2">
								<span class="h-1.5 w-1.5 rounded-full bg-brand-green"></span>
								Operacion 24/7
							</div>
						</div>
					</div>
					<div class="grid gap-6 sm:grid-cols-2">
						<div class="bento-card sm:col-span-2" data-accent="purple">
							<p class="section-label text-brand-purple">Stack de precision</p>
							<h3 class="mt-4 text-2xl font-mono">Arquitectura confiable</h3>
							<ul class="mt-4 space-y-3 text-sm text-white/70">
								<li class="flex gap-3">
									<span class="mt-2 h-1.5 w-1.5 rounded-full bg-brand-green"></span>
									Observabilidad en tiempo real para auditoria y seguridad.
								</li>
								<li class="flex gap-3">
									<span class="mt-2 h-1.5 w-1.5 rounded-full bg-brand-purple"></span>
									Modelos de IA con control de calidad y pruebas continuas.
								</li>
								<li class="flex gap-3">
									<span class="mt-2 h-1.5 w-1.5 rounded-full bg-brand-green"></span>
									IoT industrial con alertas y mantenimiento predictivo.
								</li>
							</ul>
						</div>
						<StatCard
							value="+2.7M"
							label="Lineas auditadas"
							description="Codigo revisado en pipelines de mision critica."
							accent="green"
						/>
						<StatCard
							value="99.98%"
							label="Uptime"
							description="Disponibilidad en sistemas con impacto operativo."
							accent="purple"
						/>
						<div class="bento-card" data-accent="green">
							<p class="section-label text-brand-green">Respuesta</p>
							<p class="mt-4 text-3xl font-mono text-brand-green">24h</p>
							<p class="mt-3 text-sm text-white/60">Tiempo maximo para diagnostico inicial.</p>
							<div class="mt-6 h-1 w-full rounded-full bg-white/10">
								<div class="h-1 w-2/3 rounded-full bg-brand-green"></div>
							</div>
						</div>
					</div>
				</div>
			</div>
		</section>

		<section id="servicios" class="py-20">
			<div class="page-container">
				<SectionHeader
					eyebrow="Servicios"
					title="Bento grid de especialidades"
					subtitle="IA, IoT, auditoria y software con un mismo lenguaje: precision y confianza."
					accent="purple"
				/>
				<div class="mt-12 grid gap-6 lg:grid-cols-12">
					<ServiceCard
						class="lg:col-span-7"
						title="Desarrollo de Software & Apps"
						description="Aplicaciones web modernas (Astro, Vue, React) y sistemas escalables disenados para alto trafico y la mejor experiencia de usuario."
						tag="Desarrollo"
						accent="green"
					>
						<svg
							slot="icon"
							viewBox="0 0 24 24"
							fill="none"
							stroke="currentColor"
							stroke-width="1.5"
							stroke-linecap="round"
							stroke-linejoin="round"
							aria-hidden="true"
						>
							<path d="M8 6l-4 6 4 6" />
							<path d="M16 6l4 6-4 6" />
							<path d="M12 4l-2 16" />
						</svg>
					</ServiceCard>
					<ServiceCard
						class="lg:col-span-7"
						title="Ingenieria Electronica e IoT"
						description="Diseno de hardware, prototipado y sistemas embebidos. Conectamos el mundo fisico con el digital."
						tag="Hardware"
						accent="purple"
					>
						<svg
							slot="icon"
							viewBox="0 0 24 24"
							fill="none"
							stroke="currentColor"
							stroke-width="1.5"
							stroke-linecap="round"
							stroke-linejoin="round"
							aria-hidden="true"
						>
							<circle cx="6" cy="12" r="2" />
							<circle cx="18" cy="6" r="2" />
							<circle cx="18" cy="18" r="2" />
							<path d="M8 12h6M16 8l-4 4M16 16l-4-4" />
						</svg>
					</ServiceCard>
					<ServiceCard
						class="lg:col-span-5"
						title="IA & Automatizacion"
						description="Implementacion de modelos inteligentes y automatizacion de procesos para optimizar la operacion."
						tag="IA"
						accent="purple"
					>
						<svg
							slot="icon"
							viewBox="0 0 24 24"
							fill="none"
							stroke="currentColor"
							stroke-width="1.5"
							stroke-linecap="round"
							stroke-linejoin="round"
							aria-hidden="true"
						>
							<rect x="7" y="7" width="10" height="10" rx="2" />
							<path d="M9 3v4M15 3v4M9 17v4M15 17v4M3 9h4M3 15h4M17 9h4M17 15h4" />
						</svg>
					</ServiceCard>
					<ServiceCard
						class="lg:col-span-5"
						title="Auditoria y Calidad Tecnica"
						description="Revisiones de seguridad y performance para asegurar que tu stack sea invulnerable y eficiente."
						tag="Auditoria"
						accent="green"
					>
						<svg
							slot="icon"
							viewBox="0 0 24 24"
							fill="none"
							stroke="currentColor"
							stroke-width="1.5"
							stroke-linecap="round"
							stroke-linejoin="round"
							aria-hidden="true"
						>
							<path d="M12 3l7 3v6c0 5-3.5 9-7 10-3.5-1-7-5-7-10V6l7-3z" />
							<path d="M9 12l2 2 4-4" />
						</svg>
					</ServiceCard>
				</div>
			</div>
		</section>

		<section id="confianza" class="py-20">
			<div class="page-container">
				<SectionHeader
					eyebrow="Confianza"
					title="Senales claras para entornos regulados"
					subtitle="Medimos, auditamos y optimizamos con la misma precision con la que ejecutamos."
					accent="green"
				/>
				<div class="mt-12 grid gap-6 md:grid-cols-3">
					<StatCard
						value="+150K"
						label="Lineas de codigo productivo"
						description="Codigo estable y mantenible en produccion."
						accent="green"
					/>
					<StatCard
						value="99.9%"
						label="Eficiencia en sistemas electronicos"
						description="Control y rendimiento en hardware embebido."
						accent="purple"
					/>
					<StatCard
						value="100%"
						label="Trazabilidad en cada commit"
						description="Versionado y auditoria continua en cada entrega."
						accent="green"
					/>
				</div>
				<div class="mt-12 grid gap-6 lg:grid-cols-12">
					<div class="bento-card lg:col-span-7" data-accent="green">
						<p class="section-label text-brand-green">Proceso de auditoria</p>
						<h3 class="mt-4 text-2xl font-mono">Cadena de precision operacional</h3>
						<ol class="mt-6 space-y-4 text-sm text-white/70">
							<li class="flex gap-3">
								<span class="mt-2 h-1.5 w-1.5 rounded-full bg-brand-green"></span>
								Descubrimiento: mapeo de arquitectura, riesgos y dependencias.
							</li>
							<li class="flex gap-3">
								<span class="mt-2 h-1.5 w-1.5 rounded-full bg-brand-purple"></span>
								Validacion: pruebas de stress, trazas y control de accesos.
							</li>
							<li class="flex gap-3">
								<span class="mt-2 h-1.5 w-1.5 rounded-full bg-brand-green"></span>
								Ejecucion: automatizacion de auditorias y alertas proactivas.
							</li>
						</ol>
					</div>
					<div class="bento-card lg:col-span-5" data-accent="purple">
						<p class="section-label text-brand-purple">Seguridad y cumplimiento</p>
						<h3 class="mt-4 text-2xl font-mono">Standards listos</h3>
						<div class="mt-6 flex flex-wrap gap-3">
							<span class="chip">ISO 27001</span>
							<span class="chip">SOC 2 Ready</span>
							<span class="chip">OWASP</span>
							<span class="chip">NIST</span>
							<span class="chip">Zero Trust</span>
						</div>
						<p class="mt-6 text-sm text-white/60">
							Alineamos procesos y tecnologia para auditorias internas y externas.
						</p>
					</div>
				</div>
			</div>
		</section>

		<section id="contacto" class="py-20">
			<div class="page-container grid gap-12 lg:grid-cols-[0.9fr_1.1fr]">
				<div>
					<SectionHeader
						eyebrow="Contacto"
						title="Listos para elevar tu stack"
						subtitle="Comparte tu desafio y armamos un plan de auditoria, IA o IoT en menos de una semana."
						accent="green"
					/>
					<div class="mt-8 space-y-4 text-sm text-white/70">
						<div class="flex gap-3">
							<span class="mt-2 h-1.5 w-1.5 rounded-full bg-brand-green"></span>
							Diagnostico inicial y roadmap con quick wins.
						</div>
						<div class="flex gap-3">
							<span class="mt-2 h-1.5 w-1.5 rounded-full bg-brand-purple"></span>
							Equipo senior multidisciplinario para ejecucion inmediata.
						</div>
						<div class="flex gap-3">
							<span class="mt-2 h-1.5 w-1.5 rounded-full bg-brand-green"></span>
							KPI de seguridad, performance y disponibilidad.
						</div>
					</div>
					<div class="mt-8 bento-card" data-accent="green">
						<p class="section-label text-brand-green">Cobertura</p>
						<p class="mt-4 text-2xl font-mono">Latam + Global Remote</p>
						<p class="mt-3 text-sm text-white/60">
							Coordinacion con equipos internos y proveedores externos.
						</p>
					</div>
				</div>
				<ContactForm />
			</div>
		</section>
	</main>
	<Footer />
</BaseLayout>
