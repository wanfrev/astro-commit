---
import BaseLayout from "../layouts/BaseLayout.astro";
import NavBar from "../components/NavBar.astro";
import SectionHeader from "../components/SectionHeader.astro";
import StatCard from "../components/StatCard.astro";
import ContactForm from "../components/ContactForm.astro";
import Footer from "../components/Footer.astro";
import AlmareImage from "../assets/ALMARE.svg";
import BurcorImage from "../assets/Burcor.webp";
import InglobalsImage from "../assets/Inglobals.png";
import K11Image from "../assets/k11icon.png";

const getProjectImageSrc = (image: string | { src: string }) =>
	typeof image === "string" ? image : image.src;

const projects = [
	{
		title: "K11box: Smart Boxing",
		client: "K11box",
		description:
			"Ecosistema digital para entrenamiento de alto rendimiento y rankings globales.",
		image: K11Image,
		accent: "purple",
		href: "https://www.instagram.com/k11.box/",
		layout: "lg:col-span-7 lg:row-span-2",
		imageMode: "contain",
		revealClass: "reveal-left"
	},
	{
		title: "InGlobalS: AI Audit",
		client: "InGlobalS",
		description:
			"Automatización de auditorías financieras mediante modelos de Machine Learning.",
		image: InglobalsImage,
		accent: "green",
		href: "https://inglobals.com/",
		layout: "lg:col-span-5 lg:row-span-2",
		imageMode: "contain",
		revealClass: "reveal-right"
	},
	{
		title: "Burcor: Health Logistics",
		client: "Burcor Med",
		description:
			"Optimización de la cadena de suministro para dispositivos médicos críticos.",
		image: BurcorImage,
		accent: "green",
		href: "https://burcormed.net/",
		layout: "lg:col-span-6",
		imageMode: "contain",
		revealClass: "reveal-pop"
	},
	{
		title: "Almare: Med-Tech",
		client: "Almare",
		description:
			"Innovación en prótesis externas y cuidado especializado del paciente.",
		image: AlmareImage,
		accent: "purple",
		href: "https://burcormed.net/almare/",
		layout: "lg:col-span-6",
		imageMode: "contain",
		revealClass: "reveal-up-soft"
	}
];
---

<BaseLayout
	title="Commit | Soluciones a medida"
	description="Software, electronica e IA para convertir ideas en resultados."
>
	<NavBar />
	<main>
		<section class="relative overflow-hidden pt-32 pb-20">
			<div class="hero-aurora absolute inset-0 opacity-90"></div>
			<div class="hero-grid absolute inset-0 opacity-30"></div>
			<div class="glow-orb -top-24 right-0 h-72 w-72 bg-brand-purple/30 animate-float-slow"></div>
			<div class="glow-orb -bottom-24 left-0 h-72 w-72 bg-brand-green/25 animate-float"></div>
			<div class="page-container relative z-10">
					<div class="grid gap-12">
					<div class="reveal reveal-up-soft reveal-visible">
						<p class="section-label text-brand-green">Soluciones tecnológicas para tu negocio</p>
						<h1 class="mt-6 text-4xl font-mono leading-tight md:text-5xl lg:text-6xl">
							En Commit, <span class="gradient-text">hacemos realidad</span> la tecnología
							que tu negocio necesita. 
						</h1>
						<p class="mt-6 text-lg text-white/70">
							¿Tienes una idea? Nosotros la construimos. Desde webs que venden hasta
							electrónica personalizada. Soluciones a medida, en tiempo record y para
							cualquier industria. Desarrollamos herramientas que ahorran tiempo, 
							eliminan errores, organizan tu empresa y aumentan tus ventas.
						</p>
						<div class="mt-8 flex flex-wrap gap-4">
							<a class="btn-primary" href="#contacto">Agendar Consulta</a>
							<a class="btn-secondary" href="#servicios">Conoce nuestros servicios</a>
						</div>
						<div class="mt-10 grid gap-4 text-xs font-mono uppercase tracking-[0.25em] text-white/50 sm:grid-cols-3">
							<div class="flex items-center gap-2">
								<span class="h-1.5 w-1.5 rounded-full bg-brand-green"></span>
								Tiempo RÉCORD
							</div>
							<div class="flex items-center gap-2">
								<span class="h-1.5 w-1.5 rounded-full bg-brand-purple"></span>
								Lenguaje claro
							</div>
							<div class="flex items-center gap-2">
								<span class="h-1.5 w-1.5 rounded-full bg-brand-green"></span>
								Soporte total
							</div>
						</div>
					</div>
						<div class="stagger-grid grid gap-6 md:grid-cols-3">
							<div class="reveal reveal-tilt bento-card md:col-span-3 p-6 sm:p-8 flex flex-col justify-center" data-accent="purple">
								<p class="section-label text-brand-purple text-xs font-bold uppercase tracking-wider">Beneficios claros</p>
								<h3 class="mt-4 text-3xl font-mono">Tecnología sin complicaciones</h3>
								<ul class="mt-6 space-y-4 text-sm text-white/70">
									<li class="flex items-center gap-3">
										<span class="h-2 w-2 rounded-full bg-brand-green"></span>
										Diseño funcional, no solo estético: Páginas web creadas para convertir
										 visitantes en clientes, no solo para verse bien.
									</li>
									<li class="flex items-center gap-3">
										<span class="h-2 w-2 rounded-full bg-brand-purple"></span>
										Sistemas hechos a tu medida: Olvida las plantillas rígidas.
										Construimos el software que se adapta a tu forma de trabajar.
									</li>
									<li class="flex items-center gap-3">
										<span class="h-2 w-2 rounded-full bg-brand-green"></span>
										Soporte real, cuando lo necesitas: No somos un proveedor que desaparece. 
										Estamos contigo en cada paso hasta que tu operación esté funcionando a la perfección.
									</li>
								</ul>
							</div>

							<StatCard
								value="Días"
								label="Primer prototipo"
								description="No creemos en esperas infinitas; queremos que veas tu visión cobrar vida y que puedas tocarla, probarla y mejorarla cuanto antes."
								accent="green"
								class="reveal reveal-left min-h-60 flex flex-col justify-between p-6"
							/>

							<StatCard
								value="Semanas"
								label="De la idea a una solución funcional."
								description="Tu solución operativa, lista en semanas. 
								Desarrollamos con metodologías ágiles para que tu negocio empiece a ver resultados reales en tiempo récord, sin complicaciones técnicas."
								accent="purple"
								class="reveal reveal-right min-h-60 flex flex-col justify-between p-6"
							/>

							<div class="reveal reveal-pop bento-card min-h-60 flex flex-col justify-between p-6" data-accent="green">
								<div>
									<p class="section-label text-brand-green text-xs font-bold uppercase tracking-wider">Respuesta rápida para diagnóstico inicial.</p>
									<p class="mt-4 text-4xl font-mono text-brand-green">Horas</p>
									<p class="mt-3 text-sm text-white/60">Estamos presentes cuando nos necesitas. Desde tu primera consulta, 
										te brindamos un diagnóstico claro y profesional en cuestión de horas. Tu tiempo es nuestra prioridad.
										</p>
								</div>
							</div>
						</div>
				</div>
			</div>
		</section>

		<section id="servicios" class="py-24">
			<div class="page-container">
				<div class="reveal reveal-up-soft">
					<SectionHeader
						eyebrow="Servicios"
						title="Soluciones que entienden tu negocio"
						subtitle="Elegimos la mejor tecnología para tu objetivo, no al revés."
						accent="purple"
					/>
				</div>

				<div class="stagger-grid mt-16 grid gap-4 lg:grid-cols-12 lg:auto-rows-[18rem]">
					<div class="reveal reveal-left group relative flex flex-col justify-end overflow-hidden rounded-3xl border border-white/10 bg-brand-ink p-8 transition-all duration-500 hover:border-brand-green/30 lg:col-span-7">
						<div class="absolute inset-0 bg-[radial-gradient(circle_at_20%_20%,rgba(0,255,65,0.35),transparent_55%)] opacity-10 transition-opacity duration-500 group-hover:opacity-20"></div>

						<div class="absolute top-8 right-8 text-brand-green opacity-20 transition-all duration-500 group-hover:scale-110 group-hover:opacity-100">
							<svg
								class="h-16 w-16"
								viewBox="0 0 24 24"
								fill="none"
								stroke="currentColor"
								stroke-width="1.5"
								stroke-linecap="round"
								stroke-linejoin="round"
								aria-hidden="true"
							>
								<path d="M8 6l-4 6 4 6" />
								<path d="M16 6l4 6-4 6" />
								<path d="M12 4l-2 16" />
							</svg>
						</div>

						<div class="relative z-10">
							<p class="mb-2 text-[10px] font-mono uppercase tracking-[0.3em] text-brand-green">
								Desarrollo
							</p>
							<h3 class="text-2xl font-mono text-white">Sitios Web y Apps a Medida</h3>
							<div class="grid grid-rows-[0fr] transition-all duration-500 group-hover:grid-rows-[1fr]">
								<p class="mt-4 overflow-hidden text-sm leading-relaxed text-white/60">
									No usamos plantillas. Creamos herramientas digitales rápidas y fáciles de usar que se adaptan exactamente a tu flujo de trabajo.
								</p>
							</div>
						</div>
					</div>

					<div class="reveal reveal-right group relative flex flex-col justify-end overflow-hidden rounded-3xl border border-white/10 bg-brand-ink p-8 transition-all duration-500 hover:border-brand-purple/30 lg:col-span-5">
						<div class="absolute inset-0 bg-[radial-gradient(circle_at_20%_20%,rgba(138,43,226,0.35),transparent_55%)] opacity-10 transition-opacity duration-500 group-hover:opacity-20"></div>

						<div class="absolute top-8 right-8 text-brand-purple opacity-20 transition-all duration-500 group-hover:scale-110 group-hover:opacity-100">
							<svg
								class="h-16 w-16"
								viewBox="0 0 24 24"
								fill="none"
								stroke="currentColor"
								stroke-width="1.5"
								stroke-linecap="round"
								stroke-linejoin="round"
								aria-hidden="true"
							>
								<rect x="7" y="7" width="10" height="10" rx="2" />
								<path d="M9 3v4M15 3v4M9 17v4M15 17v4M3 9h4M3 15h4M17 9h4M17 15h4" />
							</svg>
						</div>

						<div class="relative z-10">
							<p class="mb-2 text-[10px] font-mono uppercase tracking-[0.3em] text-brand-purple">
								IA & Automatización
							</p>
							<h3 class="text-2xl font-mono text-white">Negocio en Piloto Automático</h3>
							<div class="grid grid-rows-[0fr] transition-all duration-500 group-hover:grid-rows-[1fr]">
								<p class="mt-4 overflow-hidden text-sm leading-relaxed text-white/60">
									Algoritmos inteligentes que eliminan tareas repetitivas y errores humanos, permitiendo que tu equipo se enfoque en lo que importa.
								</p>
							</div>
						</div>
					</div>

					<div class="reveal reveal-pop group relative flex flex-col justify-end overflow-hidden rounded-3xl border border-white/10 bg-brand-ink p-8 transition-all duration-500 hover:border-brand-purple/30 lg:col-span-5">
						<div class="absolute inset-0 bg-[radial-gradient(circle_at_20%_20%,rgba(138,43,226,0.35),transparent_55%)] opacity-10 transition-opacity duration-500 group-hover:opacity-20"></div>

						<div class="absolute top-8 right-8 text-brand-purple opacity-20 transition-all duration-500 group-hover:scale-110 group-hover:opacity-100">
							<svg
								class="h-16 w-16"
								viewBox="0 0 24 24"
								fill="none"
								stroke="currentColor"
								stroke-width="1.5"
								stroke-linecap="round"
								stroke-linejoin="round"
								aria-hidden="true"
							>
								<circle cx="6" cy="12" r="2" />
								<circle cx="18" cy="6" r="2" />
								<circle cx="18" cy="18" r="2" />
								<path d="M8 12h6M16 8l-4 4M16 16l-4-4" />
							</svg>
						</div>

						<div class="relative z-10">
							<p class="mb-2 text-[10px] font-mono uppercase tracking-[0.3em] text-brand-purple">
								Hardware
							</p>
							<h3 class="text-2xl font-mono text-white">Desarrollo de ideas únicas</h3>
							<div class="grid grid-rows-[0fr] transition-all duration-500 group-hover:grid-rows-[1fr]">
								<p class="mt-4 overflow-hidden text-sm leading-relaxed text-white/60">
									Diseño de circuitos y prototipado electrónico para conectar el mundo físico con el digital.
								</p>
							</div>
						</div>
					</div>

					<div class="reveal reveal-left group relative flex flex-col justify-end overflow-hidden rounded-3xl border border-white/10 bg-brand-ink p-8 transition-all duration-500 hover:border-brand-green/30 lg:col-span-7">
						<div class="absolute inset-0 bg-[radial-gradient(circle_at_20%_20%,rgba(0,255,65,0.35),transparent_55%)] opacity-10 transition-opacity duration-500 group-hover:opacity-20"></div>

						<div class="absolute top-8 right-8 text-brand-green opacity-20 transition-all duration-500 group-hover:scale-110 group-hover:opacity-100">
							<svg
								class="h-16 w-16"
								viewBox="0 0 24 24"
								fill="none"
								stroke="currentColor"
								stroke-width="1.5"
								stroke-linecap="round"
								stroke-linejoin="round"
								aria-hidden="true"
							>
								<path d="M12 3l7 3v6c0 5-3.5 9-7 10-3.5-1-7-5-7-10V6l7-3z" />
								<path d="M9 12l2 2 4-4" />
							</svg>
						</div>

						<div class="relative z-10">
							<p class="mb-2 text-[10px] font-mono uppercase tracking-[0.3em] text-brand-green">
								Seguridad
							</p>
							<h3 class="text-2xl font-mono text-white">Tecnología Blindada</h3>
							<div class="grid grid-rows-[0fr] transition-all duration-500 group-hover:grid-rows-[1fr]">
								<p class="mt-4 overflow-hidden text-sm leading-relaxed text-white/60">
									Auditoría de sistemas y optimización de infraestructura para garantizar que tu negocio nunca se detenga.
								</p>
							</div>
						</div>
					</div>

					<div class="reveal reveal-fade group relative overflow-hidden rounded-3xl border border-white/10 bg-zinc-950 p-12 text-center lg:col-span-12 lg:row-span-2 lg:p-20">
						<div class="absolute inset-0 opacity-20 mask-[radial-gradient(ellipse_at_center,black,transparent)]">
							<div class="absolute inset-0 bg-[linear-gradient(to_right,#ffffff05_1px,transparent_1px),linear-gradient(to_bottom,#ffffff05_1px,transparent_1px)] bg-size-[32px_32px]"></div>
						</div>

						<div class="absolute top-1/2 left-1/2 h-80 w-80 -translate-x-1/2 -translate-y-1/2 rounded-full bg-brand-purple/20 opacity-50 blur-[120px] transition-all duration-700 group-hover:scale-150 group-hover:bg-brand-green/30"></div>

						<div class="relative z-10">
							<span class="mb-4 inline-block rounded-full border border-brand-green/30 bg-brand-green/10 px-4 py-1 font-mono text-[10px] uppercase tracking-[0.3em] text-brand-green">
								Universal & Agnóstico
							</span>

							<h3 class="font-mono text-3xl tracking-tight text-white md:text-4xl lg:text-5xl">
								Sin límites de <span class="text-white/40">industria</span> o <span class="text-white/40">tecnología</span>.
							</h3>

							<p class="mx-auto mt-6 max-w-xl text-lg leading-relaxed text-white/50">
								Nos adaptamos a tu presupuesto y entorno actual para construir el futuro de tu empresa.
							</p>

							<div class="mt-10">
								<p class="font-mono text-xl italic md:text-2xl">
									<span class="bg-linear-to-r from-brand-green via-white to-brand-purple bg-clip-text text-transparent">
										"Si se puede imaginar, en Commit se puede programar."
									</span>
								</p>
							</div>

							<div class="mt-12 flex justify-center gap-2">
								<div class="h-1 w-12 rounded-full bg-brand-green/50"></div>
								<div class="h-1 w-4 rounded-full bg-white/20"></div>
								<div class="h-1 w-1 rounded-full bg-white/10"></div>
							</div>
						</div>
					</div>
				</div>
			</div>
		</section>

		<section id="proyectos" class="py-24">
			<div class="page-container">
				<div class="reveal reveal-up-soft">
					<SectionHeader
						eyebrow="Portfolio"
						title="Proyectos destacados"
						subtitle="Soluciones reales para negocios reales."
						accent="purple"
					/>
				</div>

				<div class="stagger-grid mt-16 grid gap-4 md:grid-cols-2 lg:grid-cols-12 lg:auto-rows-[16rem]">
					{projects.map((project) => (
						<a
							href={project.href}
							target={project.href.startsWith("http") ? "_blank" : undefined}
							rel={project.href.startsWith("http") ? "noreferrer" : undefined}
							class={`reveal ${project.revealClass} group relative flex min-h-72 flex-col justify-end overflow-hidden rounded-3xl border border-white/10 bg-brand-ink ${project.layout}`}
						>
							<img
								src={getProjectImageSrc(project.image)}
								alt={project.title}
								loading="lazy"
								class={`absolute inset-0 h-full w-full ${project.imageMode === "contain" ? "object-contain p-10" : "object-cover"} opacity-80 transition duration-700 group-hover:scale-105 group-hover:opacity-60`}
							/>

							<div
								class={`absolute inset-0 opacity-45 transition-opacity duration-500 group-hover:opacity-75 ${project.accent === "purple" ? "bg-[radial-gradient(circle_at_center,rgba(138,43,226,0.35),transparent_60%)]" : "bg-[radial-gradient(circle_at_center,rgba(0,255,65,0.35),transparent_60%)]"}`}
							></div>

							<div class="absolute inset-0 bg-linear-to-t from-black via-black/20 to-transparent"></div>

							<div class="relative z-10 p-8 transition-transform duration-500 group-hover:-translate-y-2">
								<p
									class={`mb-2 text-[10px] font-mono uppercase tracking-[0.2em] ${project.accent === "purple" ? "text-brand-purple" : "text-brand-green"}`}
								>
									{project.client}
								</p>
								<h3 class="text-2xl font-mono leading-tight text-white">{project.title}</h3>
								<div class="mt-3 grid grid-rows-[0fr] transition-all duration-500 group-hover:grid-rows-[1fr]">
									<p class="overflow-hidden text-sm text-white/60 opacity-0 transition-opacity duration-500 group-hover:opacity-100 line-clamp-2">
										{project.description}
									</p>
								</div>
							</div>
						</a>
					))}
				</div>
			</div>
		</section>

		<section id="confianza" class="py-24">
			<div class="page-container">
				<div class="reveal reveal-up-soft">
					<SectionHeader
						eyebrow="Por qué Commit"
						title="Confianza sin tecnicismos"
						subtitle="Tres razones simples para elegirnos desde el primer día."
						accent="green"
					/>
				</div>
				<div class="stagger-grid mt-16 grid gap-6 md:grid-cols-3">
					<div class="reveal reveal-left group relative flex min-h-88 flex-col justify-end overflow-hidden rounded-3xl border border-white/10 bg-zinc-950 p-8 transition-all duration-500 hover:border-brand-green/30">
						<div class="absolute top-8 right-8 text-brand-green opacity-35 transition-all duration-500 group-hover:scale-110 group-hover:opacity-100">
							<svg
								class="h-14 w-14"
								viewBox="0 0 24 24"
								fill="none"
								stroke="currentColor"
								stroke-width="1.6"
								stroke-linecap="round"
								stroke-linejoin="round"
								aria-hidden="true"
							>
								<path d="M5 13a7 7 0 1 1 14 0" />
								<path d="M12 13l4-4" />
								<path d="M8 10l-1-1" />
								<path d="M16 10l1-1" />
								<circle cx="12" cy="13" r="1" fill="currentColor" stroke="none" />
							</svg>
						</div>

						<div class="absolute inset-0 bg-[radial-gradient(circle_at_20%_20%,rgba(16,185,129,0.1),transparent_60%)] opacity-30 transition-opacity duration-500 group-hover:opacity-60"></div>

						<div class="relative z-10">
							<p class="mb-2 text-[10px] font-mono uppercase tracking-[0.3em] text-brand-green">
								Velocidad
							</p>
							<h3 class="text-2xl font-mono text-white">Tiempo récord</h3>
							<div class="grid grid-rows-[0fr] transition-all duration-500 group-hover:grid-rows-[1fr]">
								<p class="mt-4 overflow-hidden text-sm leading-relaxed text-white/50">
									Sabemos que el tiempo es dinero. Entregamos prototipos funcionales más rápido que la competencia.
								</p>
							</div>
						</div>
					</div>

					<div class="reveal reveal-pop group relative flex min-h-88 flex-col justify-end overflow-hidden rounded-3xl border border-white/10 bg-zinc-950 p-8 transition-all duration-500 hover:border-brand-purple/30">
						<div class="absolute top-8 right-8 text-brand-purple opacity-35 transition-all duration-500 group-hover:scale-110 group-hover:opacity-100">
							<svg
								class="h-14 w-14"
								viewBox="0 0 24 24"
								fill="none"
								stroke="currentColor"
								stroke-width="1.6"
								stroke-linecap="round"
								stroke-linejoin="round"
								aria-hidden="true"
							>
								<path d="M5 6h10a4 4 0 0 1 4 4v4a4 4 0 0 1-4 4H10l-4 4v-4H5a4 4 0 0 1-4-4v-4a4 4 0 0 1 4-4z" />
								<path d="M8 10h6" />
								<path d="M8 13h4" />
								<path d="M17 8c1.5 0 2.8.6 3.8 1.6" />
								<path d="M17 16c1.5 0 2.8-.6 3.8-1.6" />
							</svg>
						</div>

						<div class="absolute inset-0 bg-[radial-gradient(circle_at_20%_20%,rgba(138,43,226,0.1),transparent_60%)] opacity-30 transition-opacity duration-500 group-hover:opacity-60"></div>

						<div class="relative z-10">
							<p class="mb-2 text-[10px] font-mono uppercase tracking-[0.3em] text-brand-purple">
								Comunicación
							</p>
							<h3 class="text-2xl font-mono text-white">Hablamos tu idioma</h3>
							<div class="grid grid-rows-[0fr] transition-all duration-500 group-hover:grid-rows-[1fr]">
								<p class="mt-4 overflow-hidden text-sm leading-relaxed text-white/50">
