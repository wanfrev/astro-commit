---
import BaseLayout from "../layouts/BaseLayout.astro";
import NavBar from "../components/NavBar.astro";
import SectionHeader from "../components/SectionHeader.astro";
import ServiceCard from "../components/ServiceCard.astro";
import StatCard from "../components/StatCard.astro";
import ContactForm from "../components/ContactForm.astro";
import Footer from "../components/Footer.astro";
---

<BaseLayout
	title="Commit | Soluciones a medida"
	description="Software, electronica e IA para convertir ideas en resultados."
>
	<NavBar />
	<main>
		<section class="relative overflow-hidden pt-32 pb-20">
			<div class="hero-aurora absolute inset-0 opacity-90"></div>
			<div class="hero-grid absolute inset-0 opacity-30"></div>
			<div class="glow-orb -top-24 right-0 h-72 w-72 bg-brand-purple/30 animate-float-slow"></div>
			<div class="glow-orb -bottom-24 left-0 h-72 w-72 bg-brand-green/25 animate-float"></div>
			<div class="page-container relative z-10">
				<div class="grid gap-12 lg:grid-cols-[1.1fr_0.9fr] lg:items-center">
					<div>
						<p class="section-label text-brand-green">Soluciones tecnologicas para tu negocio</p>
						<h1 class="mt-6 text-4xl font-mono leading-tight md:text-5xl lg:text-6xl">
							En Commit, <span class="gradient-text">hacemos realidad</span> la tecnologia
							que tu negocio necesita
						</h1>
						<p class="mt-6 text-lg text-white/70">
							¿Tienes una idea? Nosotros la construimos. Desde webs que venden hasta
							electronica personalizada. Soluciones a medida, en tiempo record y para
							cualquier industria.
						</p>
						<div class="mt-8 flex flex-wrap gap-4">
							<a class="btn-primary" href="#contacto">Agendar consulta</a>
							<a class="btn-secondary" href="#servicios">Explorar servicios</a>
						</div>
						<div class="mt-10 grid gap-4 text-xs font-mono uppercase tracking-[0.25em] text-white/50 sm:grid-cols-3">
							<div class="flex items-center gap-2">
								<span class="h-1.5 w-1.5 rounded-full bg-brand-green"></span>
								Tiempo record
							</div>
							<div class="flex items-center gap-2">
								<span class="h-1.5 w-1.5 rounded-full bg-brand-purple"></span>
								Lenguaje claro
							</div>
							<div class="flex items-center gap-2">
								<span class="h-1.5 w-1.5 rounded-full bg-brand-green"></span>
								Soporte total
							</div>
						</div>
					</div>
					<div class="grid gap-6 sm:grid-cols-2">
						<div class="bento-card sm:col-span-2" data-accent="purple">
							<p class="section-label text-brand-purple">Beneficios claros</p>
							<h3 class="mt-4 text-2xl font-mono">Resultados sin friccion</h3>
							<ul class="mt-4 space-y-3 text-sm text-white/70">
								<li class="flex gap-3">
									<span class="mt-2 h-1.5 w-1.5 rounded-full bg-brand-green"></span>
									Prototipos funcionales en dias, no meses.
								</li>
								<li class="flex gap-3">
									<span class="mt-2 h-1.5 w-1.5 rounded-full bg-brand-purple"></span>
									Soluciones hechas a medida, sin plantillas.
								</li>
								<li class="flex gap-3">
									<span class="mt-2 h-1.5 w-1.5 rounded-full bg-brand-green"></span>
									Acompanamiento total hasta que todo funciona.
								</li>
							</ul>
						</div>
						<StatCard
							value="Días"
							label="Primer prototipo"
							description="Validas la idea con algo real."
							accent="green"
						/>
						<StatCard
							value="Semanas"
							label="Entrega inicial"
							description="De la idea a una solucion funcional."
							accent="purple"
						/>
						<div class="bento-card" data-accent="green">
							<p class="section-label text-brand-green">Respuesta</p>
							<p class="mt-4 text-3xl font-mono text-brand-green">Horas</p>
							<p class="mt-3 text-sm text-white/60">Respuesta rapida para diagnostico inicial.</p>
							<div class="mt-6 h-1 w-full rounded-full bg-white/10">
								<div class="h-1 w-2/3 rounded-full bg-brand-green"></div>
							</div>
						</div>
					</div>
				</div>
			</div>
		</section>

		<section id="servicios" class="py-20">
			<div class="page-container">
				<SectionHeader
					eyebrow="Servicios"
					title="Soluciones que entienden tu negocio"
					subtitle="Elegimos la mejor tecnologia para tu objetivo, no al reves."
					accent="purple"
				/>
				<div class="mt-12 grid gap-6 lg:grid-cols-12">
					<ServiceCard
						class="lg:col-span-7"
						title="Sitios Web y Apps a Medida"
						description="No usamos plantillas. Creamos herramientas digitales rapidas y faciles de usar que se adaptan exactamente a lo que tu empresa hace."
						tag="Desarrollo"
						accent="green"
					>
						<svg
							slot="icon"
							viewBox="0 0 24 24"
							fill="none"
							stroke="currentColor"
							stroke-width="1.5"
							stroke-linecap="round"
							stroke-linejoin="round"
							aria-hidden="true"
						>
							<path d="M8 6l-4 6 4 6" />
							<path d="M16 6l4 6-4 6" />
							<path d="M12 4l-2 16" />
						</svg>
					</ServiceCard>
					<ServiceCard
						class="lg:col-span-7"
						title="Hardware e Inventos Propios"
						description="Necesitas un dispositivo fisico que no existe en el mercado? Disenamos y fabricamos circuitos y aparatos inteligentes para automatizar tu entorno."
						tag="Hardware"
						accent="purple"
					>
						<svg
							slot="icon"
							viewBox="0 0 24 24"
							fill="none"
							stroke="currentColor"
							stroke-width="1.5"
							stroke-linecap="round"
							stroke-linejoin="round"
							aria-hidden="true"
						>
							<circle cx="6" cy="12" r="2" />
							<circle cx="18" cy="6" r="2" />
							<circle cx="18" cy="18" r="2" />
							<path d="M8 12h6M16 8l-4 4M16 16l-4-4" />
						</svg>
					</ServiceCard>
					<ServiceCard
						class="lg:col-span-5"
						title="Tu Negocio en Piloto Automatico"
						description="Usamos inteligencia artificial para que las tareas repetitivas se hagan solas. Ahorra tiempo y evita errores humanos."
						tag="IA"
						accent="purple"
					>
						<svg
							slot="icon"
							viewBox="0 0 24 24"
							fill="none"
							stroke="currentColor"
							stroke-width="1.5"
							stroke-linecap="round"
							stroke-linejoin="round"
							aria-hidden="true"
						>
							<rect x="7" y="7" width="10" height="10" rx="2" />
							<path d="M9 3v4M15 3v4M9 17v4M15 17v4M3 9h4M3 15h4M17 9h4M17 15h4" />
						</svg>
					</ServiceCard>
					<ServiceCard
						class="lg:col-span-5"
						title="Tecnologia Blindada y Segura"
						description="Revisamos que tus sistemas actuales funcionen perfecto, sean seguros y no te den sorpresas desagradables."
						tag="Auditoria"
						accent="green"
					>
						<svg
							slot="icon"
							viewBox="0 0 24 24"
							fill="none"
							stroke="currentColor"
							stroke-width="1.5"
							stroke-linecap="round"
							stroke-linejoin="round"
							aria-hidden="true"
						>
							<path d="M12 3l7 3v6c0 5-3.5 9-7 10-3.5-1-7-5-7-10V6l7-3z" />
							<path d="M9 12l2 2 4-4" />
						</svg>
					</ServiceCard>
					<div class="bento-card lg:col-span-12" data-accent="green">
						<h3 class="text-2xl font-mono">Sin limites de industria o tecnologia</h3>
						<p class="mt-2 text-white/70">
							No importa si eres una startup, una fabrica o un comercio local. Nos
							adaptamos a tu presupuesto y entorno.
							<strong class="text-white">
								Si se puede imaginar, en Commit se puede programar.
							</strong>
						</p>
						<div class="mt-6 flex flex-wrap gap-4 text-xs font-mono uppercase tracking-[0.2em] text-white/50">
							<span>#Salud</span>
							<span>#Logistica</span>
							<span>#E-commerce</span>
							<span>#Educacion</span>
							<span>#Industria</span>
						</div>
					</div>
				</div>
			</div>
		</section>

		<section id="confianza" class="py-20">
			<div class="page-container">
				<SectionHeader
					eyebrow="Por que Commit"
					title="Confianza sin tecnicismos"
					subtitle="Tres razones simples para elegirnos desde el primer dia."
					accent="green"
				/>
				<div class="mt-12 grid gap-6 md:grid-cols-3">
					<div class="bento-card" data-accent="green">
						<p class="section-label text-brand-green">Tiempo record</p>
						<h3 class="mt-4 text-xl font-mono">Prototipos mas rapido</h3>
						<p class="mt-3 text-sm text-white/70">
							Sabemos que el tiempo es dinero. Entregamos prototipos funcionales
							mas rapido que la competencia.
						</p>
					</div>
					<div class="bento-card" data-accent="purple">
						<p class="section-label text-brand-purple">Lenguaje claro</p>
						<h3 class="mt-4 text-xl font-mono">Hablamos tu idioma</h3>
						<p class="mt-3 text-sm text-white/70">
							Somos ingenieros, pero explicamos todo sin tecnicismos. Solo
							resultados y decisiones claras.
						</p>
					</div>
					<div class="bento-card" data-accent="green">
						<p class="section-label text-brand-green">Soporte total</p>
						<h3 class="mt-4 text-xl font-mono">Acompanamiento completo</h3>
						<p class="mt-3 text-sm text-white/70">
							Te acompanamos desde el primer dibujo hasta que la solucion esta
							funcionando al 100%.
						</p>
					</div>
				</div>
			</div>
		</section>

		<section id="contacto" class="py-20">
			<div class="page-container grid gap-12 lg:grid-cols-[0.9fr_1.1fr]">
				<div>
					<SectionHeader
						eyebrow="Contacto"
						title="Hablemos de tu idea"
						subtitle="Cuentanos tu objetivo y te proponemos una solucion clara, con tiempos y presupuesto real."
						accent="green"
					/>
					<div class="mt-8 space-y-4 text-sm text-white/70">
						<div class="flex gap-3">
							<span class="mt-2 h-1.5 w-1.5 rounded-full bg-brand-green"></span>
							Entendemos tu necesidad en una llamada corta.
						</div>
						<div class="flex gap-3">
							<span class="mt-2 h-1.5 w-1.5 rounded-full bg-brand-purple"></span>
							Propuesta clara con pasos simples y tiempos reales.
						</div>
						<div class="flex gap-3">
							<span class="mt-2 h-1.5 w-1.5 rounded-full bg-brand-green"></span>
							Acompanamiento completo hasta la entrega.
						</div>
					</div>
					<div class="mt-8 bento-card" data-accent="green">
						<p class="section-label text-brand-green">Cobertura</p>
						<p class="mt-4 text-2xl font-mono">Latam + Global Remote</p>
						<p class="mt-3 text-sm text-white/60">
							Coordinacion con equipos internos y proveedores externos.
						</p>
					</div>
				</div>
				<ContactForm />
			</div>
		</section>
	</main>
	<Footer />
</BaseLayout>
